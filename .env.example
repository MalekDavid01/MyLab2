# ── .env.example ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Model / Inference ─────────────────────────────────────────────────────────
CHECKPOINT_DIR=checkpoints/best
IMG_SIZE=256
PORT=5000

# ── Training ──────────────────────────────────────────────────────────────────
SEGFORMER_MODEL=nvidia/mit-b0
EPOCHS=5
BATCH_SIZE=2
LEARNING_RATE=6e-5
NUM_WORKERS=0

# ── Dataset ───────────────────────────────────────────────────────────────────
SAM_CHECKPOINT_PATH=sam_vit_h_4b8939.pth
IOU_THRESHOLD=0.3
DATA_OUTPUT_DIR=data
MAX_SAMPLES=100

# ── Evaluation ────────────────────────────────────────────────────────────────
EVAL_OUTPUT_DIR=eval_outputs
VIZ_SAMPLES=8

# ── Secrets (HuggingFace private repos, etc.) ─────────────────────────────────
HF_TOKEN=hf_your_token_here
